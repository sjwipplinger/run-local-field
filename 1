  green:  { bg: "#4FA86E", label: "Green",  star: false },
  yellow: { bg: "#E6B23C", label: "Yellow", star: false },
  red:    { bg: "#CF4B2C", label: "Red",    star: false },
  grey:   { bg: "#2A231B", label: "No log", star: false },
