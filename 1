import { useState, useEffect, useRef } from "react";

// RUN LOCAL — FIELD
// Per-day D2D tracker. Funnel-locked counts (Doors >= Interviews >= Sold),
// Submit -> confirm -> first-time full-screen takeover. Calendar rates each day
// by effort OR results. Roles: derek = read-only, admin = edits everything +
// goals, test = takeover on every submit, anyone else = normal editable rep.

